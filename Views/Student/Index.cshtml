@model List<StudentManagementSystem.Models.Student>

@{
    ViewData["Title"] = "Students";
}

<h2>All Students</h2>
<a href="/Student/Create" class="btn btn-primary mb-3">+ Add New Student</a>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Email</th>
            <th>Age</th>
            <th>Course</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var student in Model)
        {
            <tr>
                <td>@student.Id</td>
                <td>@student.Name</td>
                <td>@student.Email</td>
                <td>@student.Age</td>
                <td>@student.Course</td>
                <td>
                    <a href="/Student/Edit/@student.Id" class="btn btn-warning btn-sm">Edit</a>
                    <a href="/Student/Delete/@student.Id" class="btn btn-danger btn-sm">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>